# Copy this file to .env.local and fill in values. Never commit .env.local.

# Sentry — create a project at sentry.io/organizations/randomorium
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Shopify Buy Button — get from Shopify > Sales channels > Buy Button
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_COLLECTION_ID=

# Anthropic Claude API — for Hangover Helper AI itinerary generation
# The app works without this key via fallback itineraries
ANTHROPIC_API_KEY=

# API-Football via RapidAPI — for Football Games player search
# Get from rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=
